  },
  {
    id:5, name:"Slip-glazed Jug",
    objectState:"NC", rendererState:"GA",
    type:"Ceramic",
    artist:"Dorothy Hay",
    rendererLocation:"Atlanta, GA",
    date:"1938",
    maker:"Unknown Catawba Valley Potter",
    owner:"Mint Museum",
    origin:"Catawba Valley, NC",
    imageUrl:"",
    desc:"Alkaline glaze, stoneware"
  },
  {
    id:6, name:"Conestoga Wagon Toolbox",
    objectState:"PA", rendererState:"OH",
    type:"Tool",
    artist:"Fritz Kredel",
    rendererLocation:"Cincinnati, OH",
    date:"1936",
    maker:"Unknown Lancaster Craftsman",
    owner:"Philadelphia Museum",
    origin:"Lancaster County, PA",
    imageUrl:"",
    desc:"Wrought iron, painted pine"
  },
  {
    id:7, name:"Majolica Pitcher",
    objectState:"NJ", rendererState:"PA",
    type:"Ceramic",
    artist:"Perkins Harnly",
    rendererLocation:"Philadelphia, PA",
    date:"1940",
    maker:"Griffen, Smith & Hill",
    owner:"NGA Collection",
    origin:"Phoenixville, PA",
    imageUrl:"",
    desc:"Earthenware, polychrome glaze"
  },
  {
    id:8, name:"Jacquard Coverlet",
    objectState:"OH", rendererState:"NY",
    type:"Textile",
    artist:"Louis Raynaud",
    rendererLocation:"New York, NY",
    date:"1937",
    maker:"Jacob Ardner",
    owner:"Zoar State Memorial",
    origin:"Zoar Colony, OH",
    imageUrl:"",
    desc:"Wool & cotton, Jacquard loom"
  },
];

const stateCentroids = {
  AL:{x:595,y:430},AK:{x:115,y:520},AZ:{x:195,y:380},AR:{x:540,y:400},
  CA:{x:110,y:330},CO:{x:290,y:320},CT:{x:820,y:205},DE:{x:795,y:260},
  FL:{x:660,y:490},GA:{x:635,y:430},HI:{x:280,y:535},ID:{x:195,y:215},
  IL:{x:560,y:310},IN:{x:590,y:310},IA:{x:530,y:270},KS:{x:450,y:340},
  KY:{x:620,y:360},LA:{x:545,y:460},ME:{x:855,y:150},MD:{x:780,y:285},
  MA:{x:830,y:195},MI:{x:610,y:240},MN:{x:510,y:195},MS:{x:570,y:430},
  MO:{x:535,y:350},MT:{x:250,y:185},NE:{x:440,y:290},NV:{x:160,y:295},
  NH:{x:825,y:175},NJ:{x:805,y:255},NM:{x:290,y:405},NY:{x:780,y:210},
  NC:{x:710,y:370},ND:{x:430,y:185},OH:{x:650,y:295},OK:{x:460,y:385},
  OR:{x:140,y:230},PA:{x:745,y:255},RI:{x:838,y:210},SC:{x:700,y:400},
  SD:{x:430,y:235},TN:{x:610,y:385},TX:{x:445,y:450},UT:{x:220,y:320},
  VT:{x:810,y:175},VA:{x:730,y:320},WA:{x:155,y:175},WV:{x:700,y:315},
  WI:{x:560,y:235},WY:{x:285,y:250},DC:{x:778,y:295}
};

let activeFilter = 'all';
let selectedId = null;

function setFilter(f, btn) {
  activeFilter = f;
  document.querySelectorAll('.fb').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  selectedId = null;
  closePanel();
  renderList();
  updateMapColors();
}

function filteredObjects() {
  return activeFilter === 'all' ? objects : objects.filter(o => o.type === activeFilter);
}

function renderList() {
  const list = document.getElementById('obj-list');
  list.innerHTML = filteredObjects().map(o => `
    <div class="oi ${selectedId===o.id?'sel':''}" onclick="selectObj(${o.id})">
      <div class="on">${o.name}</div>
      <div class="os">${o.origin} · ${o.date}</div>
      <span class="tag t-type">${o.type}</span>
      <span class="tag t-rend">rendered in ${o.rendererState}</span>
    </div>
  `).join('');
}

function updateMapColors() {
  const fo = filteredObjects();
  const objStates = new Set(fo.map(o => o.objectState));
  const rendStates = new Set(fo.map(o => o.rendererState));
  document.querySelectorAll('.sp').forEach(p => {
    p.classList.remove('active-obj','active-rend','sel');
    const sid = p.getAttribute('data-state');
    if (selectedId) {
      const obj = objects.find(o => o.id === selectedId);
      if (sid === obj.objectState) p.classList.add('sel');
      else if (sid === obj.rendererState) p.classList.add('active-rend');
    } else {
      if (objStates.has(sid)) p.classList.add('active-obj');
      else if (rendStates.has(sid)) p.classList.add('active-rend');
    }
  });
}

function selectObj(id) {
  selectedId = id;
  const obj = objects.find(o => o.id === id);
  renderList();
  updateMapColors();
  drawConnection(obj);
  showPanel(obj);
}

function drawConnection(obj) {
  const cg = document.getElementById('conn-g');
  const dg = document.getElementById('dots-g');
  cg.innerHTML = ''; dg.innerHTML = '';
  const oc = stateCentroids[obj.objectState];
  const rc = stateCentroids[obj.rendererState];
  if (!oc || !rc) return;
  if (obj.objectState !== obj.rendererState) {
    const cx = (oc.x+rc.x)/2;
    const cy = Math.min(oc.y,rc.y)-50;
    const path = document.createElementNS('http://www.w3.org/2000/svg','path');
    path.setAttribute('d',`M${rc.x},${rc.y} Q${cx},${cy} ${oc.x},${oc.y}`);
    path.setAttribute('class','conn');
    path.setAttribute('marker-end','url(#arr)');
    cg.appendChild(path);
  }
  [[oc,'#185FA5'],[rc,'#7F77DD']].forEach(([c,col]) => {
    const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');
    circle.setAttribute('cx',c.x); circle.setAttribute('cy',c.y);
    circle.setAttribute('r','7'); circle.setAttribute('fill',col);
    circle.setAttribute('stroke','#fff'); circle.setAttribute('stroke-width','2');
    dg.appendChild(circle);
  });
}

function showPanel(obj) {
  document.getElementById('panel-title').textContent = obj.name;
  document.getElementById('panel-fields').innerHTML = `
    <b>Artist/Renderer:</b> ${obj.artist} (${obj.rendererLocation})<br>
    <b>Date:</b> ${obj.date}<br>
    <b>Object maker:</b> ${obj.maker}<br>
    <b>Owner:</b> ${obj.owner}<br>
    <b>Description:</b> ${obj.desc}
  `;
  const connText = obj.objectState !== obj.rendererState
    ? `Renderer traveled from ${obj.rendererState} to document this object in ${obj.objectState}`
    : `Renderer was local to the object's origin`;
  document.getElementById('panel-conn').textContent = '⬦ ' + connText;
  const imgEl = document.getElementById('panel-img');
  if (obj.imageUrl) {
    imgEl.outerHTML = `<img id="panel-img" src="${obj.imageUrl}" style="width:72px;height:72px;object-fit:cover;border-radius:4px;border:0.5px solid var(--color-border-tertiary);flex-shrink:0;" onerror="this.style.display='none'">`;
  }
  document.getElementById('panel').classList.add('show');
}

function closePanel() {
  document.getElementById('panel').classList.remove('show');
  document.getElementById('conn-g').innerHTML = '';
  document.getElementById('dots-g').innerHTML = '';
  selectedId = null;
  updateMapColors();
  renderList();
}

async function buildMap() {
  const svg = document.getElementById('map-svg');
  const g = document.getElementById('states-g');
  try {
    const us = await fetch('https://cdn.jsdelivr.net/npm/us-atlas@3/states-10m.json').then(r=>r.json());
    const states = topojson.feature(us, us.objects.states);
    const proj = d3.geoAlbersUsa().scale(1100).translate([480,300]);
    const path = d3.geoPath().projection(proj);
    const fips = {"01":"AL","02":"AK","04":"AZ","05":"AR","06":"CA","08":"CO","09":"CT","10":"DE","11":"DC","12":"FL","13":"GA","15":"HI","16":"ID","17":"IL","18":"IN","19":"IA","20":"KS","21":"KY","22":"LA","23":"ME","24":"MD","25":"MA","26":"MI","27":"MN","28":"MS","29":"MO","30":"MT","31":"NE","32":"NV","33":"NH","34":"NJ","35":"NM","36":"NY","37":"NC","38":"ND","39":"OH","40":"OK","41":"OR","42":"PA","44":"RI","45":"SC","46":"SD","47":"TN","48":"TX","49":"UT","50":"VT","51":"VA","53":"WA","54":"WV","55":"WI","56":"WY"};
    states.features.forEach(f => {
      const abbr = fips[f.id.toString().padStart(2,'0')];
      if (!abbr) return;
      const el = document.createElementNS('http://www.w3.org/2000/svg','path');
      el.setAttribute('d', path(f));
      el.setAttribute('class','sp');
      el.setAttribute('data-state', abbr);
      el.addEventListener('click', () => {
        const match = filteredObjects().find(o => o.objectState === abbr);
        if (match) selectObj(match.id);
      });
      g.appendChild(el);
      const c = proj(d3.geoCentroid(f));
      if (c) {
        stateCentroids[abbr] = {x:Math.round(c[0]), y:Math.round(c[1])};
      }
    });
    updateMapColors();
  } catch(e) {
    g.innerHTML = '<text x="50%" y="50%" text-anchor="middle" fill="var(--color-text-secondary)" font-size="13">Map loading failed</text>';
  }
}

buildMap();
renderList();
</script>
