
<style>
*{box-sizing:border-box;margin:0;padding:0;}
#app{display:flex;height:640px;background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);overflow:hidden;}
#sidebar{width:300px;flex-shrink:0;border-right:0.5px solid var(--color-border-tertiary);display:flex;flex-direction:column;}
#sidebar-header{padding:14px 16px;border-bottom:0.5px solid var(--color-border-tertiary);}
#sidebar-header p{font-size:11px;font-weight:500;color:var(--color-text-secondary);letter-spacing:0.07em;text-transform:uppercase;margin-bottom:3px;}
#sidebar-header h1{font-size:16px;font-weight:500;color:var(--color-text-primary);}
#filter-row{padding:10px 14px;border-bottom:0.5px solid var(--color-border-tertiary);display:flex;gap:6px;flex-wrap:wrap;}
.fb{font-size:11px;padding:4px 10px;border-radius:20px;border:0.5px solid var(--color-border-secondary);background:transparent;color:var(--color-text-secondary);cursor:pointer;}
.fb.on{background:#185FA5;color:#fff;border-color:#185FA5;}
#obj-list{flex:1;overflow-y:auto;}
.oi{padding:12px 14px;border-bottom:0.5px solid var(--color-border-tertiary);cursor:pointer;transition:background 0.1s;}
.oi:hover,.oi.sel{background:var(--color-background-secondary);}
.on{font-size:13px;font-weight:500;color:var(--color-text-primary);margin-bottom:2px;}
.os{font-size:11px;color:var(--color-text-secondary);}
.tag{display:inline-block;font-size:10px;padding:2px 7px;border-radius:10px;margin-top:5px;margin-right:3px;}
.t-type{background:#E6F1FB;color:#0C447C;}
.t-rend{background:#EEEDFE;color:#3C3489;}
#map-area{flex:1;position:relative;overflow:hidden;background:#f0ede6;}
#map-svg{width:100%;height:100%;}
.sp{fill:#c8c2b4;stroke:#fff;stroke-width:1;cursor:pointer;transition:fill 0.15s;}
.sp:hover{fill:#85B7EB;}
.sp.active-obj{fill:#378ADD;}
.sp.active-rend{fill:#AFA9EC;}
.sp.sel{fill:#185FA5;}
.conn{stroke:#534AB7;stroke-width:1.8;stroke-dasharray:5 3;fill:none;opacity:0.75;}
.ndot{fill:#185FA5;stroke:#fff;stroke-width:2;}
.rdot{fill:#7F77DD;stroke:#fff;stroke-width:2;}
#panel{position:absolute;bottom:0;left:0;right:0;background:var(--color-background-primary);border-top:0.5px solid var(--color-border-tertiary);padding:14px 16px;transform:translateY(100%);transition:transform 0.2s;}
#panel.show{transform:translateY(0);}
#panel-img{width:72px;height:72px;object-fit:cover;border-radius:4px;border:0.5px solid var(--color-border-tertiary);flex-shrink:0;background:var(--color-background-secondary);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--color-text-secondary);}
#panel-body{flex:1;min-width:0;}
#panel-title{font-size:14px;font-weight:500;color:var(--color-text-primary);margin-bottom:2px;}
#panel-fields{font-size:11px;color:var(--color-text-secondary);line-height:1.8;}
#panel-conn{font-size:11px;color:#534AB7;margin-top:6px;}
#close-btn{position:absolute;top:10px;right:12px;background:none;border:none;font-size:16px;cursor:pointer;color:var(--color-text-secondary);}
#legend{position:absolute;top:10px;right:10px;background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-md);padding:9px 12px;font-size:11px;color:var(--color-text-secondary);}
.lr{display:flex;align-items:center;gap:7px;margin-bottom:4px;}
.lr:last-child{margin-bottom:0;}
.ld{width:10px;height:10px;border-radius:50%;}
.ll{width:20px;border-top:2px dashed #534AB7;}
</style>

<div id="app">
<div id="sidebar">
  <div id="sidebar-header">
    <p>Speculative Portfolio</p>
    <h1>Index of American Design</h1>
  </div>
  <div id="filter-row">
    <button class="fb on" onclick="setFilter('all',this)">All</button>
    <button class="fb" onclick="setFilter('Ceramic',this)">Ceramic</button>
    <button class="fb" onclick="setFilter('Textile',this)">Textile</button>
    <button class="fb" onclick="setFilter('Furniture',this)">Furniture</button>
    <button class="fb" onclick="setFilter('Tool',this)">Tool</button>
  </div>
  <div id="obj-list"></div>
</div>
<div id="map-area">
  <svg id="map-svg" viewBox="0 0 960 600" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <marker id="arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
        <path d="M0,0 L0,6 L6,3 z" fill="#534AB7" opacity="0.8"/>
      </marker>
    </defs>
    <g id="states-g"></g>
    <g id="conn-g"></g>
    <g id="dots-g"></g>
  </svg>
  <div id="legend">
    <div class="lr"><div class="ld" style="background:#378ADD"></div> Object's state</div>
    <div class="lr"><div class="ld" style="background:#7F77DD"></div> Renderer's state</div>
    <div class="lr"><div class="ll"></div> Renderer → Object</div>
  </div>
  <div id="panel">
    <button id="close-btn" onclick="closePanel()">✕</button>
    <div style="display:flex;gap:12px;align-items:flex-start;">
      <div id="panel-img">No image</div>
      <div id="panel-body">
        <div id="panel-title"></div>
        <div id="panel-fields"></div>
        <div id="panel-conn"></div>
      </div>
    </div>
  </div>
</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js"></script>
<script>
const objects = [
  {
    id:1, name:"Lion and Ball Figurine",
    objectState:"VT", rendererState:"DC",
    type:"Ceramic",
    artist:"Ella Josephine Sterling",
    rendererLocation:"Washington, DC",
    date:"May 1936",
    maker:"Anonymous Craftsman (Bennington Pottery)",
    owner:"Major Gist Blair",
    origin:"Bennington, VT",
    imageUrl:"https://images.collection.cooperhewitt.org/404086_a03b2f9f4f5f0c1b_b.jpg",
    desc:"Glazed ceramic figurine, Bennington ware"
  },
  {
    id:2, name:"Shaker Chair",
    objectState:"MA", rendererState:"NY",
    type:"Furniture",
    artist:"Lucile Chabot",
    rendererLocation:"New York, NY",
    date:"1936",
    maker:"Shaker Community",
    owner:"Hancock Shaker Village",
    origin:"Hancock, MA",
    imageUrl:"",
    desc:"Woven tape seat, maple frame"
  },
  {
    id:3, name:"Navajo Blanket",
    objectState:"NM", rendererState:"NM",
    type:"Textile",
    artist:"E. Boyd",
    rendererLocation:"Albuquerque, NM",
    date:"1939",
    maker:"Unknown Navajo Weaver",
    owner:"Museum of New Mexico",
    origin:"Northern New Mexico",
    imageUrl:"",
    desc:"Wool, vegetal dye, geometric pattern"
  },
  {
    id:4, name:"Pennsylvania Dutch Hex Sign",
    objectState:"PA", rendererState:"IL",
    type:"Textile",
    artist:"Rudolph Ruzicka",
    rendererLocation:"Chicago, IL",
    date:"1937",
    maker:"Unknown Pennsylvania German Craftsman",
